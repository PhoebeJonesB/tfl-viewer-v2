#Get data
SUBJID <- c(1102,1502,1008,1058,1099,1265,1296,1355,1470,1472,1902)
EVENT_DATE <- c("15MAY2020","24JUN2020","12JAN2020","17FEB2020","28APR2020","07APR2020","04MAY2020","09MAY2020","17MAR2020","03MAY2020","16MAR2020")
START_DATE <- c("01JAN2020","05JAN2020","09JAN2020","20JAN2020","04FEB2020","19FEB2020","07FEB2020","24FEB2020","15JAN2020","29JAN2020","02FEB2020")
DIFF <- c(136,172,4,29,85,-49,88,-76,63,96,44)
CENSOR <- c(0,1,0,0,1,1,0,1,0,0,0)
ADTTE <- data.frame(SUBJID,EVENT_DATE,START_DATE,DIFF,CENSOR)
colnames(adtte)
colnames(ADTTE)
View(ADTTE)
str(ADTTE)
ADTTE$CENSOR<-factor(ADTTE$CENSOR)
str(ADTTE)
library(dplyr)
library(plyr)
ADTTE$CNSR<-recode(ADTTE$CNSR,"0"="No","1"="Yes")
ADTTE$CNSR<-recode(ADTTE$CENSOR,"0"="No","1"="Yes")
View(ADTTE)
ADTTE$CNSR2<-ifelse(ADTTE$CENSOR="0","No","Yes")
ADTTE$CNSR2<-ifelse(ADTTE$CENSOR=="0","No","Yes")
View(ADTTE)
adtte_sub=subset(ADTTE,CENSOR=="0")
adtte_sub
adtte_sub2<-adtte[,which(ADTTE,CENSOR=="0")]
adtte_sub2<-ADTTE[,which(ADTTE,CENSOR=="0")]
adtte_sub2<-ADTTE[,which(ADTTE$CENSOR=="0")]
adtte_sub2<-ADTTE[which(ADTTE$CENSOR=="0"),]
adtte_sub2
adtte_sub2$DIFF[adtte_sub2$SUBJID==1470]<-90
