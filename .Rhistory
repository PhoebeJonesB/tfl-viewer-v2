#merge
dataset1 <- data.frame(pid=c(1,2,3), visit=c(11,22,33))
dataset2 <- data.frame(pid=c(1,2,3,4,5) ,vis=c(34,35,36,36,37))
dataset3 <- data.frame(id=c(1,2,3,4,5,6,7), labresult=c(20,32,25,28,23,26,38))
dataset4<-merge (dataset1,dataset2, all=FALSE)
dataset4
dataset5<-merge (dataset1,dataset2, all=TRUE)
dataset5
dataset6<-merge (dataset1,dataset2, by="pid",all.x=TRUE)
dataset6
dataset7<-merge (dataset1,dataset2, by="pid",all.y=TRUE)
dataset7
dataset8<-merge (dataset1,dataset3, by.x="pid",by.y="id",all.x=TRUE)
dataset8
dataset9<-merge (dataset1,dataset3, by.x="pid",by.y="id",all.y=TRUE)
dataset9
dataset10<-merge (dataset1,dataset3, by=NULL)
dataset10
dataset2a<-dataset2[c(4,5),]
dataset3a<-dataset3[-c(4:7),]
Reduce(function(x, y) merge(x, y, all = TRUE), list(dataset1,dataset2a,dataset3a))
